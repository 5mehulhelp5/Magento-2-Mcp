<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="freento_mcp_acl_role" resource="default" engine="innodb" comment="MCP ACL Roles">
        <column xsi:type="int" name="role_id" unsigned="true" nullable="false" identity="true" comment="Role ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Role Name"/>
        <column xsi:type="varchar" name="access_type" nullable="false" length="20" default="specified" comment="Access Type: all or specified"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="role_id"/>
        </constraint>
    </table>

    <table name="freento_mcp_acl_role_tool" resource="default" engine="innodb" comment="MCP ACL Role Tools">
        <column xsi:type="int" name="id" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="int" name="role_id" unsigned="true" nullable="false" comment="Role ID"/>
        <column xsi:type="varchar" name="tool_name" nullable="false" length="255" comment="Tool Name"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="FK_MCP_ROLE_TOOL_ROLE_ID"
                    table="freento_mcp_acl_role_tool" column="role_id"
                    referenceTable="freento_mcp_acl_role" referenceColumn="role_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="UNQ_MCP_ROLE_TOOL">
            <column name="role_id"/>
            <column name="tool_name"/>
        </constraint>
        <index referenceId="IDX_MCP_ROLE_TOOL_ROLE_ID" indexType="btree">
            <column name="role_id"/>
        </index>
    </table>

    <!-- OAuth 2.0 Tables -->
    <table name="freento_mcp_oauth_client" resource="default" engine="innodb" comment="MCP OAuth Clients">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="client_id" nullable="false" length="64" comment="Client ID"/>
        <column xsi:type="text" name="client_secret" nullable="false" comment="Client Secret (encrypted)"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Client Name"/>
        <column xsi:type="int" name="role_id" unsigned="true" nullable="true" comment="MCP Role ID"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Is Active"/>
        <column xsi:type="varchar" name="token_hash" nullable="true" length="255" comment="Access Token Hash"/>
        <column xsi:type="int" name="admin_user_id" unsigned="true" nullable="true" comment="Admin User ID"/>
        <column xsi:type="varchar" name="otp_hash" nullable="true" length="255" comment="One-Time Password Hash"/>
        <column xsi:type="timestamp" name="otp_expires_at" nullable="true" comment="OTP Expires At"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="UNQ_MCP_OAUTH_CLIENT_ID">
            <column name="client_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="UNQ_MCP_OAUTH_CLIENT_TOKEN_HASH">
            <column name="token_hash"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="UNQ_MCP_OAUTH_CLIENT_OTP_HASH">
            <column name="otp_hash"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="FK_MCP_OAUTH_CLIENT_ROLE_ID"
                    table="freento_mcp_oauth_client" column="role_id"
                    referenceTable="freento_mcp_acl_role" referenceColumn="role_id"
                    onDelete="SET NULL"/>
        <constraint xsi:type="foreign" referenceId="FK_MCP_OAUTH_CLIENT_ADMIN_USER_ID"
                    table="freento_mcp_oauth_client" column="admin_user_id"
                    referenceTable="admin_user" referenceColumn="user_id"
                    onDelete="SET NULL"/>
    </table>

    <table name="freento_mcp_oauth_code" resource="default" engine="innodb" comment="MCP OAuth Authorization Codes">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="code_hash" nullable="false" length="255" comment="Code Hash"/>
        <column xsi:type="varchar" name="client_id" nullable="false" length="64" comment="Client ID"/>
        <column xsi:type="int" name="admin_user_id" unsigned="true" nullable="false" comment="Admin User ID"/>
        <column xsi:type="varchar" name="state" nullable="true" length="255" comment="State"/>
        <column xsi:type="varchar" name="code_challenge" nullable="true" length="128" comment="PKCE Code Challenge"/>
        <column xsi:type="varchar" name="code_challenge_method" nullable="true" length="10" comment="PKCE Challenge Method (S256 or plain)"/>
        <column xsi:type="timestamp" name="expires_at" nullable="false" comment="Expires At"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="UNQ_MCP_OAUTH_CODE_HASH">
            <column name="code_hash"/>
        </constraint>
        <index referenceId="IDX_MCP_OAUTH_CODE_CLIENT_ID" indexType="btree">
            <column name="client_id"/>
        </index>
    </table>

</schema>
