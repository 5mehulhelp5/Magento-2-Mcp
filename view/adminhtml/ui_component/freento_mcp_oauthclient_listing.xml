<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">freento_mcp_oauthclient_listing.freento_mcp_oauthclient_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add" class="Freento\Mcp\Block\Adminhtml\OAuthClient\AddButton"/>
        </buttons>
        <spinner>freento_mcp_oauthclient_columns</spinner>
        <deps>
            <dep>freento_mcp_oauthclient_listing.freento_mcp_oauthclient_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="freento_mcp_oauthclient_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">entity_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Freento_Mcp::oauth_clients</aclResource>
        <dataProvider class="Freento\Mcp\Ui\DataProvider\OAuthClientListingDataProvider" name="freento_mcp_oauthclient_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="freento_mcp_oauthclient_columns">
        <column name="entity_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Client Name</label>
            </settings>
        </column>
        <column name="created_by">
            <settings>
                <filter>text</filter>
                <label translate="true">Created By</label>
            </settings>
        </column>
        <column name="client_id">
            <settings>
                <filter>text</filter>
                <label translate="true">Client ID</label>
            </settings>
        </column>
        <column name="role_name">
            <settings>
                <filter>text</filter>
                <label translate="true">MCP Role</label>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
                <options>
                    <option name="active" xsi:type="array">
                        <item name="value" xsi:type="string">1</item>
                        <item name="label" xsi:type="string" translate="true">Active</item>
                    </option>
                    <option name="inactive" xsi:type="array">
                        <item name="value" xsi:type="string">0</item>
                        <item name="label" xsi:type="string" translate="true">Inactive</item>
                    </option>
                </options>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created At</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Freento\Mcp\Ui\Component\Listing\Column\OAuthClientActions">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
